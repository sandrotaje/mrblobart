---
import '../styles/Footer.css';
const year = new Date().getFullYear();
---

<footer class="footer">
  <div class="container">
    <div class="social-icons">
      <a
        href="https://instagram.com/mrblobart"
        target="_blank"
        rel="noopener noreferrer"
        aria-label="Instagram"
      >
        <img
          src="https://simpleicons.org/icons/instagram.svg"
          alt="Instagram"
          class="social-icon"
        />
      </a>
      <a
        href="https://www.facebook.com/mrblobart"
        target="_blank"
        rel="noopener noreferrer"
        aria-label="Facebook"
      >
        <img
          src="https://simpleicons.org/icons/facebook.svg"
          alt="Facebook"
          class="social-icon"
        />
      </a>
      <a
        href="https://www.youtube.com/@mrblobart"
        target="_blank"
        rel="noopener noreferrer"
        aria-label="YouTube"
      >
        <img
          src="https://simpleicons.org/icons/youtube.svg"
          alt="YouTube"
          class="social-icon"
        />
      </a>
    </div>
    <div class="copyright">
      &copy; {year} Mr Blob Art. All rights reserved.
    </div>
  </div>
</footer>
